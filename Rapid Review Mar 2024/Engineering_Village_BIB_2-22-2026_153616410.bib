@article{20250817902778 ,
language = {English},
copyright = {Compilation and indexing terms, Copyright 2026 Elsevier Inc.},
copyright = {Compendex},
title = {Pixels and people: Exploring the dynamics of engagement and disengagement in Minecraft's multiplayer realm},
journal = {International Journal of Human Computer Studies},
author = {Doan, Vi Anh and Alexandrovsky, Dmitry and van Sintemaartensdijk, Iris and Gerling, Kathrin and Friehs, Maximilian A.},
volume = {198},
year = {2025},
issn = {10715819},
abstract = {Engagement is often viewed as the holy grail of digital experiences, particularly video games, while disengagement is seen as a consequence of poor design. This study attempts to flip the script, exploring disengagement as a natural part of the user journey rather than a failure of game design. Focusing on the popular open-world game Minecraft, the research investigates dynamics triggering engagement and disengagement in the multiplayer mode through the lenses of established frameworks like the Process Model of Engagement as well as the Mechanics, Dynamics, and Aesthetics model. Semi-structured focus-group interviews conducted with 15 participants analyzed using Mayring's content analysis revealed social connections, novelty, progression, goal-driven gameplay, and adrenaline-fueled combat as key drivers that keep players hooked. Yet, the very act of achieving goals, absence of friends, overplay, setbacks, skill gaps, negative interactions, and the demands of the real world can trigger a powerful urge to disengage. Far from a design flaw, this research expands the body of literature suggesting that disengagement is a vital component of user autonomy. By redefining success beyond mere engagement metrics, the study paves the way for responsible gaming practices that empower players to make informed choices about their level of involvement. It beckons us to embrace a holistic vision of genuinely sustainable, ethical, and meaningful digital experiences that respect user autonomy and cultivate healthy engagement patterns. © 2025 The Authors},
keywords = {Game design;},
note = {Disengagement;Dynamic triggering;Engagement;Game design;Game dynamic;Minecraft;Multiplayers;Open world;User autonomy;Video-games;},
URL = {http://dx.doi.org/10.1016/j.ijhcs.2025.103465},
} 


@inproceedings{20254719520752 ,
language = {English},
copyright = {Compilation and indexing terms, Copyright 2026 Elsevier Inc.},
copyright = {Compendex},
title = {A Co-designed Serious Game to Promote Parental Emotion Regulation: Development and Pilot Usability Study},
journal = {Lecture Notes in Computer Science},
author = {Silva, Eliana and Pereira, Monica and Reis, Luis Paulo},
volume = {16243 LNCS},
year = {2026},
pages = {327 - 332},
issn = {03029743},
address = {Lucerne, Switzerland},
abstract = {Parenthood poses challenges to emotion regulation (ER), especially during the transition to adolescence, a period of major emotional and social changes. Despite programs for improving emotional skills, access to mental health services is limited. To address these challenges, this study presents the development of a serious game (SG), called EmoBalance, to help parents of young adolescents identify emotions and learn ER strategies based on the Process Model of Emotion Regulation. The game design involved interviews with the target audience and relevant stakeholders. A pilot usability evaluation was conducted with three psychologists and three mothers to assess their experience of and satisfaction with the game. The mothers identified with the topics addressed in the SG. The psychologists recognized the game’s potential for clinical application. Additional mechanics to increase parental engagement are recommended. By helping parents to deal with their own emotions and increase their knowledge of how to model and teach ER processes to their adolescents, it is also expected to contribute to the development of these skills in adolescents. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2026.},
key = {Serious games},
keywords = {Game design;Software design;Usability engineering;},
note = {Adolescent;Co-designs;Emotion regulation strategy;Emotion regulations;Emotional change;Mental health services;Parent;Regulation development;Social changes;Usability studies;},
URL = {http://dx.doi.org/10.1007/978-3-032-10518-9_28},
} 


@inproceedings{20260219904623 ,
language = {English},
copyright = {Compilation and indexing terms, Copyright 2026 Elsevier Inc.},
copyright = {Compendex},
title = {Dashboard Design for Educational Video Game Designers: A Designer-Centered Approach},
journal = {Lecture Notes in Networks and Systems},
author = {Dankov, Yavor},
volume = {1707 LNNS},
year = {2026},
pages = {385 - 394},
issn = {23673370},
address = {Athens, Greece},
abstract = {The paper presents the essential designer-centered requirements for designing specialized dashboards that enable the visualization of results from educational video game sessions. These dashboards are specifically intended for use by designer-educators, supporting them in designing and enhancing these games. Based on these essential designer-centered requirements, the paper presents a formal process model that demonstrates how designers can utilize the primary functionalities of the specialized dashboard of the DIZU-EVG (Data visualIZation instrUment for Educational Video Games) tool. The model focuses on using the Designers Dashboard functionalities of the DIZU-EVG instrument to visualize data crucial for designer-educators, related to the outcomes of educational video games developed within a modern software platform. Designing specialized dashboards based on the users who will utilize them is a design approach centered on the needs and goals of the educational designers. The dashboard functionalities of the DIZU-EVG tool will significantly contribute to expanding the tool’s capabilities to visualize valuable and useful data in a way that is understandable and useful for educational designers, providing insights into the educational video games they design. Thanks to these key functionalities, designers will be able to explore the educational video games they have designed and created, draw meaningful conclusions about the games’ success or failure, and take informed actions to improve them. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2026.},
key = {Serious games},
keywords = {Formal methods;Game design;Interactive computer graphics;User centered design;},
note = {Dashboard design;Data visualization instrument for educational video game instrument;Design approaches;Educational video games;Formal process models;Game-based Learning;Games designers;Software platforms;Visualization instrument;},
URL = {http://dx.doi.org/10.1007/978-3-032-10824-1_30},
} 


@inproceedings{20254919628832 ,
language = {English},
copyright = {Compilation and indexing terms, Copyright 2026 Elsevier Inc.},
copyright = {Compendex},
title = {ExerPlainable Experiences - Mapping Experiences to an Interdisciplinary Design Process of a VR Fall Prevention Exergame},
journal = {1st Annual Conference on Human-Computer Interaction and Sports, SportsHCI 2025},
author = {Ciemer, Celina and Linke, Mary and Braun, Axel and Ghellal, Sabiha and Schott, Nadja},
year = {2025},
address = {Enschede, Netherlands},
abstract = {The lack of transparent design structures in fall prevention exergames limits understanding and reproducibility. Unified interdisciplinary models and reporting standards are needed to integrate design concepts and procedures into exergame design. This study employs the Co-Creative Interdisciplinary Exergame Design Process Model with Extended Reflection (CIEMER) to develop a fall prevention exergame. In a three-week study, 16 healthy, community-dwelling older adults completed six 60-minute exergame sessions. Semi-structured interviews after sessions 1, 3, and 6 captured participant perspectives at early, mid, and late stages of the intervention. Responses were analyzed thematically. The results show that experiences of design aspects and process decisions were linked to underlying concepts and procedures, generating actionable insights. By presenting the process and outcomes, this study provides a transparent framework for future research. It further emphasizes the importance of reporting design decisions and processes to deepen the understanding of factors influencing evaluation outcomes. © 2025 Copyright held by the owner/author(s).},
key = {Accident prevention},
keywords = {Game design;Human computer interaction;Interactive computer graphics;Interactive computer systems;Product design;},
note = {Design structure;Design-process;Exergames;Experience mappings;Fall prevention;Immersive virtual reality;Inter-disciplinary designs;Interdisciplinary;Interdisciplinary modeling;Reproducibilities;},
URL = {http://dx.doi.org/10.1145/3749385.3749394},
} 



