@INPROCEEDINGS{10645544,
  author={Elbert, Nico and Flath, Christoph M.},
  booktitle={2024 IEEE Conference on Games (CoG)}, 
  title={Process Mining for Game Analytics}, 
  year={2024},
  volume={},
  number={},
  pages={1-4},
  abstract={This paper explores the integration of process mining techniques and the User Behavior Mining (UBM) Framework within game analytics, using a expansive dataset from Age of Empires II. We demonstrate how these methodologies can be used to systematically analyze and interpret complex player behaviors across various skill levels. Employing techniques such as trace clustering and directly-follows-graphs, we identify distinct behavioral patterns and quantify differences in strategy adherence. Additionally, conformance checking reveals the impact of deviations from standard build orders on game outcomes. Our findings underscore the potential of PM and UBM as powerful diagnostic tools in game analytics, offering scalable and structured approaches to enhance player interaction understanding. The successful application of these methodologies not only introduces a scalable and structured approach to quantifying complex player dynamics but also opens up the entire range of process mining methodologies, algorithms, and software solutions available. This advancement enables the gaming industry to leverage sophisticated analytical tools previously confined to other domains.},
  keywords={Process mining;Industries;Heuristic algorithms;Software algorithms;Games;Software;Standards;Process Mining;User Behavior Mining;Game Analytics;Player Behavior Analysis;Conformance Checking},
  doi={10.1109/CoG60054.2024.10645544},
  ISSN={2325-4289},
  month={Aug},}@INPROCEEDINGS{11311214,
  author={Piotopoulos, Stavros and Sakkopoulos, Evangelos},
  booktitle={2025 16th International Conference on Information, Intelligence, Systems & Applications (IISA)}, 
  title={Gamified Training for Greek Public Servants: Enhancing Procedure Knowledge Through Interactive Learning}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={The efficiency and effectiveness of public services are crucial for societal well-being. However, understanding complex administrative procedures can be challenging for public servants. This can lead to errors, delays, and reduced citizen satisfaction. This paper introduces a novel training application using gamification techniques designed to enhance the learning process for Greek public servants, by using real data of administrative procedures from the MITOS portal. The proposed application integrates key elements of the procedures, such as requirements, supporting documents, costs, and steps modeled by BPMN (Business Process Model and Notation) [1], into interactive games modules that feature quizzes, puzzles and scenario-based simulations. By transforming traditionally static content into engaging learning experiences, the proposed solution aims to improve comprehension and operational efficiency within the public sector. The initial examination of developing such an application demonstrates the feasibility of combining API-driven data acquisition with modern web-based gamification techniques [2]. A pilot evaluation plan is also outlined to assess user engagement and learning outcomes. This work contributes to relatively limited research in the field of gamification in public administration training, offering practical insights for integrating official process data into interactive training platforms.},
  keywords={Training;Costs;Data acquisition;Organizations;Data models;Serious games;Delays;Portals;Testing;Gamification;Public Sector Training;Administrative Procedures;Serious Games;Interactive Learning;mitos.gov.gr;Greece},
  doi={10.1109/IISA66859.2025.11311214},
  ISSN={},
  month={July},}
